<?xml version="1.0" encoding="utf-8"?>
<!--
    TV / 大屏专属尺寸：宽度 >= 820dp（约 6.5" 以上的大屏设备）启用。
    间距、字号、卡片内边距都放大，让电视 3 米外可读。
-->
<resources>
    <!-- 主页 Hero -->
    <dimen name="hero_title_size">72sp</dimen>
    <dimen name="hero_subtitle_size">22sp</dimen>
    <dimen name="hero_padding_top">24dp</dimen>
    <dimen name="hero_padding_bottom">40dp</dimen>

    <!-- 天气卡片 -->
    <dimen name="weather_temp_size">72sp</dimen>
    <dimen name="weather_city_size">22sp</dimen>
    <dimen name="weather_desc_size">18sp</dimen>
    <dimen name="weather_padding">32dp</dimen>

    <!-- 功能板块网格卡片
         缩小卡片尺寸 + 加大 GridLayout padding：
         - 卡片放大 1.04x 时，边缘卡片要不被屏幕边缘截断，
           GridLayout padding 至少 = 卡片放大溢出量 + 安全余量
         - func_card_margin 用作 GridLayout padding，给边缘留空间
         - func_card_padding 缩小，让卡片本身更紧凑
         - func_icon_size 缩小到 56dp（原 68dp），整体视觉更小
    -->
    <dimen name="func_card_padding">20dp</dimen>
    <dimen name="func_card_margin">28dp</dimen>
    <dimen name="func_card_radius">24dp</dimen>
    <dimen name="func_icon_size">56dp</dimen>
    <dimen name="func_icon_margin_bottom">14dp</dimen>
    <dimen name="func_title_size">18sp</dimen>
    <dimen name="func_desc_size">13sp</dimen>

    <!-- 容器水平内边距：大屏左右留白适中（避免电视两边大段空白） -->
    <dimen name="content_padding_h">32dp</dimen>
    <!-- 大屏最大内容宽度（避免电视上一行被拉过宽） -->
    <dimen name="content_max_width">1100dp</dimen>

    <!-- 设置页 -->
    <dimen name="settings_row_padding">28dp</dimen>
    <!-- 设置页内容容器水平 padding：TV 上加大，给 row 放大留余量 -->
    <dimen name="settings_content_padding_h">48dp</dimen>
    <dimen name="settings_row_title_size">20sp</dimen>
    <dimen name="settings_row_summary_size">15sp</dimen>
    <dimen name="settings_section_label_size">14sp</dimen>
    <dimen name="settings_about_size">13sp</dimen>
    <dimen name="settings_back_btn_size">56dp</dimen>

    <!-- Toolbar -->
    <dimen name="toolbar_height">72dp</dimen>
</resources>
