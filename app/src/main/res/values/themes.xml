<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 主题：液态玻璃风格（白天默认，跟随系统夜间模式自动切换） -->
    <style name="Theme.TVToolbox" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">#FFFFFFFF</item>
        <item name="colorSurface">@color/glass_fill_strong</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- 白天：状态栏/导航栏图标用深色 -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- 文本选择/对话框 -->
        <item name="materialAlertDialogTheme">@style/Theme.TVToolbox.AlertDialog</item>
    </style>

    <!-- 对话框主题：液态玻璃 -->
    <style name="Theme.TVToolbox.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorSurface">@color/glass_fill_strong</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- 全屏预览主题 -->
    <style name="Theme.TVToolbox.Fullscreen" parent="Theme.TVToolbox">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
