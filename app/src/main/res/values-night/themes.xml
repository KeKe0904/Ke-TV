<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 夜间覆盖：状态栏/导航栏图标用浅色 -->
    <style name="Theme.TVToolbox" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">#FFFFFFFF</item>
        <item name="colorSurface">@color/glass_fill_strong</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialAlertDialogTheme">@style/Theme.TVToolbox.AlertDialog</item>
    </style>

</resources>
