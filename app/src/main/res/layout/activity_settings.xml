<?xml version="1.0" encoding="utf-8"?>
<!--
    屏保设置页布局。

    全屏显示 + 放大不被截断的关键（与 activity_main.xml 一致）：
    1. 根布局 **不设** fitsSystemWindows，让背景层（LiquidBackgroundView）延伸到屏幕边缘
       （SettingsActivity 已 setDecorFitsSystemWindows(false)，inset 由 toolbar 单独处理）
    2. 所有祖先容器都设 clipChildren=false + clipToPadding=false，
       让 row 放大动画时超出自身 bounds 的部分不会被裁剪
    3. 所有 padding / textSize 用 @dimen 引用，TV 端 values-w820dp/dimens.xml 覆盖
    4. 内容容器水平 padding 在 TV 上加大（48dp），给 row 放大留余量
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.tvtoolbox.screensaver.LiquidBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_settings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@android:color/transparent"
            app:titleTextColor="@color/text_primary">

            <!-- 自定义返回按钮：替代 navigationIcon
                 手机有返回手势，TV 有返回键，但用户要求显式留一个返回按钮 -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/settings_back_btn_size"
                android:layout_height="@dimen/settings_back_btn_size"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/back"
                android:clickable="true"
                android:focusable="true" />
        </com.google.android.material.appbar.MaterialToolbar>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/settings_content_padding_h"
                android:paddingBottom="32dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- 分组：图床设置 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/cat_image_source"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_section_label_size"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- 图床类型 -->
                <LinearLayout
                    android:id="@+id/rowSourceMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_source_mode_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvSourceModeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- 图床 URL -->
                <LinearLayout
                    android:id="@+id/rowImageUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_image_url_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/settings_row_title_size"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvImageUrlValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pref_image_url_summary"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/settings_row_summary_size"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="2"
                        android:ellipsize="middle" />
                </LinearLayout>

                <!-- 切换间隔 -->
                <LinearLayout
                    android:id="@+id/rowInterval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_interval_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvIntervalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- 随机顺序 -->
                <LinearLayout
                    android:id="@+id/rowRandom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_bg"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_random_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/pref_random_summary"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchRandom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <!-- Ken Burns -->
                <LinearLayout
                    android:id="@+id/rowKenBurns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_bg"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_ken_burns_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/pref_ken_burns_summary"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchKenBurns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <!-- 分组：操作 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/cat_actions"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_section_label_size"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- 测试连通性 -->
                <LinearLayout
                    android:id="@+id/rowTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvTestTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_test_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/settings_row_title_size"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pref_test_summary"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/settings_row_summary_size"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <!-- 系统屏保设置 -->
                <LinearLayout
                    android:id="@+id/rowDreamSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_open_dream_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/pref_open_dream_settings_summary"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="24sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/about_summary"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_about_size"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.1" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
