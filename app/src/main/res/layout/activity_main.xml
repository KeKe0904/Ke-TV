<?xml version="1.0" encoding="utf-8"?>
<!--
    主页布局：手机和大屏共用，所有尺寸用 @dimen 引用。
    顶部：当前时间 + 日期（TextClock 自动刷新）
    天气卡片：城市 / 温度 / 描述 / 湿度 / 风速
    功能卡片：屏保设置 / 立即进入屏保 / 系统屏保设置 / 检查更新
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 液态背景层 -->
    <com.tvtoolbox.screensaver.LiquidBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@android:color/transparent"
            android:title="@string/hero_title"
            app:titleTextColor="@color/text_primary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/content_padding_h"
                android:paddingBottom="32dp">

                <!-- ===== 顶部时间区 ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="@dimen/hero_padding_top"
                    android:paddingBottom="@dimen/hero_padding_bottom">

                    <!-- 大字时间 -->
                    <TextClock
                        android:id="@+id/clockTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:format12Hour="HH:mm"
                        android:format24Hour="HH:mm"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/hero_title_size"
                        android:fontFamily="sans-serif-thin"
                        android:letterSpacing="0.02"
                        android:includeFontPadding="false"
                        tools:text="14:30" />

                    <!-- 日期 + 城市 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical">

                        <TextClock
                            android:id="@+id/clockDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:format12Hour="MM月dd日 EEEE"
                            android:format24Hour="MM月dd日 EEEE"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/hero_subtitle_size"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.08"
                            tools:text="7月6日 星期日" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="·"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/hero_subtitle_size" />

                        <TextView
                            android:id="@+id/tvCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/hero_subtitle_size"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.08" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== 天气卡片 ===== -->
                <LinearLayout
                    android:id="@+id/cardWeather"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:padding="@dimen/card_padding"
                    android:layout_marginBottom="@dimen/card_margin_bottom">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/card_weather_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/card_status_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°"
                            android:textColor="@color/accent_blue"
                            android:textSize="@dimen/card_status_title_size"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWeatherDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/card_weather_loading"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/card_status_desc_size"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- ===== 功能区标题 ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/cat_functions"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_section_label_size"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- 屏保设置 -->
                <LinearLayout
                    android:id="@+id/cardSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:padding="@dimen/card_padding"
                    android:layout_marginBottom="@dimen/card_margin_bottom"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/card_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_settings_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/card_desc_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/card_arrow_size" />
                </LinearLayout>

                <!-- 立即进入屏保 -->
                <LinearLayout
                    android:id="@+id/cardStartScreensaver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:padding="@dimen/card_padding"
                    android:layout_marginBottom="@dimen/card_margin_bottom"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_start_screensaver_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/card_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_start_screensaver_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/card_desc_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/card_arrow_size" />
                </LinearLayout>

                <!-- 系统屏保设置 -->
                <LinearLayout
                    android:id="@+id/cardDreamSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:padding="@dimen/card_padding"
                    android:layout_marginBottom="@dimen/card_margin_bottom"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_dream_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/card_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_dream_settings_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/card_desc_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/card_arrow_size" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/about_summary"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_about_size"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.1" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
