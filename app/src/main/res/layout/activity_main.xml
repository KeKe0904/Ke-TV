<?xml version="1.0" encoding="utf-8"?>
<!--
    主页布局：手机和大屏共用，所有尺寸用 @dimen 引用，列数用 @integer 引用。

    结构：
    1. 顶部 Hero：大字时间 + 日期 + 城市
    2. 天气卡片：温度 + 描述（点击刷新）
    3. 功能网格：6 个板块（屏保设置 / 立即进入 / 系统屏保 / 浏览器 / 检查更新 / 关于）
       每个板块 = 圆形彩色图标 + 标题 + 简短描述
       手机 2 列，大屏 3 列（@integer/grid_columns 控制）

    全屏显示 + 放大不被截断的关键：
    1. 根布局 **不设** fitsSystemWindows，让背景层（LiquidBackgroundView）延伸到屏幕边缘
       （MainActivity 已 setDecorFitsSystemWindows(false)，inset 由 toolbar 单独处理）
    2. 所有祖先容器都设 clipChildren=false + clipToPadding=false，
       让卡片放大动画时超出自身 bounds 的部分不会被裁剪
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 液态背景层：占满全屏（不受系统栏 inset 影响） -->
    <com.tvtoolbox.screensaver.LiquidBackgroundView
        android:id="@+id/liquidBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 内容层：clipChildren=false + clipToPadding=false 让子卡片放大不被截断 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@android:color/transparent"
            android:title="@string/hero_title"
            app:titleTextColor="@color/text_primary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/content_padding_h"
                android:paddingBottom="32dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- ===== 顶部时间区 ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="@dimen/hero_padding_top"
                    android:paddingBottom="@dimen/hero_padding_bottom">

                    <!-- 大字时间 -->
                    <TextClock
                        android:id="@+id/clockTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:format12Hour="HH:mm"
                        android:format24Hour="HH:mm"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/hero_title_size"
                        android:fontFamily="sans-serif-thin"
                        android:letterSpacing="0.02"
                        android:includeFontPadding="false"
                        tools:text="14:30" />

                    <!-- 日期 + 城市 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical">

                        <TextClock
                            android:id="@+id/clockDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:format12Hour="MM月dd日 EEEE"
                            android:format24Hour="MM月dd日 EEEE"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/hero_subtitle_size"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.08"
                            tools:text="7月6日 星期日" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="·"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/hero_subtitle_size" />

                        <TextView
                            android:id="@+id/tvCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/hero_subtitle_size"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.08" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== 天气卡片 ===== -->
                <LinearLayout
                    android:id="@+id/cardWeather"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/weather_padding"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical">

                    <!-- 左侧：城市 + 描述 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCity2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/weather_city_size"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvWeatherDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/card_weather_loading"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/weather_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <!-- 右侧：大字温度 -->
                    <TextView
                        android:id="@+id/tvTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°"
                        android:textColor="@color/accent_blue"
                        android:textSize="@dimen/weather_temp_size"
                        android:fontFamily="sans-serif-thin"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <!-- ===== 功能区标题 ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/cat_functions"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_section_label_size"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- ===== 功能板块网格 =====
                     用 padding 替代 margin 给卡片留放大空间：
                     - GridLayout 自身 padding = func_card_margin
                       （让边缘卡片放大后不被屏幕边缘截断）
                     - 卡片自身不再设 layout_margin，避免双重间距
                     - clipChildren=false + clipToPadding=false
                       让卡片放大时超出 padding 区域的部分也能画出来
                -->
                <androidx.gridlayout.widget.GridLayout
                    android:id="@+id/gridFunctions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:columnCount="@integer/grid_columns"
                    app:orientation="horizontal"
                    app:useDefaultMargins="false"
                    android:padding="@dimen/func_card_margin"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- 1. 屏保设置 -->
                    <LinearLayout
                        android:id="@+id/cardSettings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_blue"
                            android:src="@drawable/ic_func_settings"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_settings_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 2. 立即进入屏保 -->
                    <LinearLayout
                        android:id="@+id/cardStartScreensaver"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_pink"
                            android:src="@drawable/ic_func_play"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_start_screensaver_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_start_screensaver_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 3. 系统屏保设置 -->
                    <LinearLayout
                        android:id="@+id/cardDreamSettings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_purple"
                            android:src="@drawable/ic_func_dream"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_dream_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_dream_settings_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 4. 浏览器（占位） -->
                    <LinearLayout
                        android:id="@+id/cardBrowser"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_green"
                            android:src="@drawable/ic_func_browser"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_browser_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_browser_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 5. 检查更新 -->
                    <LinearLayout
                        android:id="@+id/cardUpdate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_orange"
                            android:src="@drawable/ic_func_update"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_app_settings_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_app_settings_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 6. 关于 -->
                    <LinearLayout
                        android:id="@+id/cardAbout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/glass_card_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="@dimen/func_card_padding"
                        android:gravity="center_horizontal"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill">

                        <ImageView
                            android:layout_width="@dimen/func_icon_size"
                            android:layout_height="@dimen/func_icon_size"
                            android:background="@drawable/func_icon_bg_gray"
                            android:src="@drawable/ic_func_about"
                            android:scaleType="center"
                            android:layout_marginBottom="@dimen/func_icon_margin_bottom" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_about_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/func_title_size"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/card_about_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/func_desc_size"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center" />
                    </LinearLayout>

                </androidx.gridlayout.widget.GridLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="@string/about_summary"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_about_size"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.1" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
