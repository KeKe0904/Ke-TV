<?xml version="1.0" encoding="utf-8"?>
<!--
    软件设置页布局。

    全屏显示 + 放大不被截断的关键（与 activity_main.xml / activity_settings.xml 一致）：
    1. 根布局 **不设** fitsSystemWindows，让背景层延伸到屏幕边缘
       （AppSettingsActivity 已 setDecorFitsSystemWindows(false)，inset 由 toolbar 单独处理）
    2. 所有祖先容器都设 clipChildren=false + clipToPadding=false，
       让 row 放大动画时超出自身 bounds 的部分不会被裁剪
    3. 所有 padding / textSize 用 @dimen 引用，TV 端 values-w820dp/dimens.xml 覆盖
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.tvtoolbox.screensaver.LiquidBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:background="@android:color/transparent"
            app:title="" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/settings_content_padding_h"
                android:paddingBottom="32dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- 分组：软件 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/cat_app_settings"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_section_label_size"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- 主题模式 -->
                <LinearLayout
                    android:id="@+id/rowThemeMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_theme_mode_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/settings_row_title_size"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvThemeModeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/pref_theme_mode_summary"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/settings_row_summary_size"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/text_tertiary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- 软件更新 -->
                <LinearLayout
                    android:id="@+id/rowCheckUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/settings_row_padding"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvCheckUpdateTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_check_update_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/settings_row_title_size"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvCheckUpdateSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pref_check_update_summary"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/settings_row_summary_size"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="@string/about_summary"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/settings_about_size"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.1" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
