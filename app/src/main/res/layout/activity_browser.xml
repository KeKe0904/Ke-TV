<?xml version="1.0" encoding="utf-8"?>
<!--
    浏览器布局：
    - 顶部 MaterialToolbar（返回 + 标题）
    - 地址栏 + 后退/前进/刷新/主页按钮 + 前往按钮
    - 加载进度条
    - WebView（基于系统 WebView / Chrome 内核）
    整体玻璃质感与 App 一致。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.tvtoolbox.screensaver.LiquidBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- 顶部 Toolbar：自定义返回按钮 + 标题 -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@android:color/transparent"
            android:title="@string/browser_title"
            app:titleTextColor="@color/text_primary">

            <ImageButton
                android:id="@+id/btnToolbarBack"
                android:layout_width="@dimen/settings_back_btn_size"
                android:layout_height="@dimen/settings_back_btn_size"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/back"
                android:clickable="true"
                android:focusable="true" />
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- 地址栏容器 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/glass_pill_bg">

            <!-- 后退 -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_browser_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/browser_back" />

            <!-- 前进 -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_browser_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/browser_forward" />

            <!-- 地址栏 / 搜索框 -->
            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:hint="@string/browser_search_hint"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:inputType="textUri|text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:background="@drawable/browser_url_bg"
                android:fontFamily="sans-serif-light" />

            <!-- 刷新 / 停止 -->
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_browser_refresh"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/browser_refresh" />

            <!-- 主页 -->
            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_browser_home"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="@string/browser_home" />

            <!-- 前往（确认搜索） -->
            <Button
                android:id="@+id/btnGo"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="56dp"
                android:layout_marginStart="4dp"
                android:text="@string/browser_go"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:background="@drawable/dialog_btn_primary"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginHorizontal="8dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <!-- WebView：基于系统 WebView（底层是 Chrome / Chromium 内核） -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/browser_webview_bg" />

    </LinearLayout>
</FrameLayout>
