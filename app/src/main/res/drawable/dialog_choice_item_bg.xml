<?xml version="1.0" encoding="utf-8"?>
<!--
    单选项背景：
    - 选中态：强调色描边 + 浅蓝填充
    - 焦点态（TV D-pad 聚焦）：强调色发光描边，让用户清楚当前在哪一项
    - 默认态：玻璃质感
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中 + 焦点 -->
    <item android:state_checked="true" android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#265B8DEF" />
            <stroke
                android:width="2.5dp"
                android:color="@color/accent_blue" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- 选中 -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A5B8DEF" />
            <stroke
                android:width="1.5dp"
                android:color="@color/accent_blue" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- 焦点（未选中） -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_fill_strong" />
            <stroke
                android:width="2.5dp"
                android:color="@color/accent_blue" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- 默认 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
