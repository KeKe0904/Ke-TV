<?xml version="1.0" encoding="utf-8"?>
<!--
    弹窗背景：与 App 主背景统一的玻璃质感
    - 比卡片更不透明（用 glass_fill_strong）让前景内容清晰可读
    - 强描边突出弹窗层次
    - 大圆角 28dp 与功能卡片视觉一致
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_fill_strong" />
    <stroke
        android:width="1.5dp"
        android:color="@color/glass_stroke_strong" />
    <corners android:radius="28dp" />
</shape>
