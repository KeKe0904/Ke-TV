<?xml version="1.0" encoding="utf-8"?>
<!--
    应用图标：纯色蓝色背景 + 白色 K 字（API 21+ 通用版本，无渐变）。
    API 24+ 用 drawable-v24/ic_launcher.xml 的渐变版本覆盖。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 纯色蓝紫背景 -->
    <path
        android:pathData="M0,0h108v108h-108z"
        android:fillColor="#FF6A5BFF" />

    <!-- K 字（白色粗 stroke，圆角端点） -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M40,30 L40,78 M40,54 L74,28 M40,54 L74,80" />

    <!-- 右下角小圆点装饰（强调色） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:fillAlpha="0.85"
        android:pathData="M82,82 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />
</vector>
